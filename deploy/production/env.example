# ---------------------------------------------------------------------------
# 生产环境必填项 (没有合理默认值 — 不填的话别上生产)
# ---------------------------------------------------------------------------

# 对外域名 — Caddy 会用它申请 Let's Encrypt 证书 + 在 CORS 配置中使用
WULING_DOMAIN=devops.example.com

# JWT 签名密钥 — 必须是足够长的随机串
# 生成: openssl rand -hex 48
WULING_JWT_SECRET=__REPLACE_ME_OR_DIE__

# Postgres 连接串 — 独立 db user，不要 superuser
# compose 里这里走容器服务名 'postgres'
# 注意: sslmode=disable 仅在 compose 内部网络隔离的本地部署下勉强可接受；
# 生产环境（跨节点 / 跨网络）请改用 sslmode=require 或 verify-full。
WULING_DB_DSN=postgres://wuling:CHANGE_ME_POSTGRES_PW@postgres:5432/wuling?sslmode=disable
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PW

# 允许跨域访问的前端来源 (多个用逗号)
WULING_HTTP_CORS_ORIGINS=https://devops.example.com

# OAuth Provider HMAC 密钥 — 用于签名我们自己签发的 OAuth token / auth-code
# (例如 Esperanta 桌面端登录)。明文绝不入库，只存 HMAC 摘要。
# 生成: openssl rand -hex 32
WULING_OAUTH_HMAC_SECRET=__REPLACE_ME_OR_DIE__

# OAuth Provider 对外宣告的绝对 origin — 写在 /.well-known/wuling-clients
# 以及 /authorize、/token 的响应里。务必带 scheme 和 host，不要末尾斜杠。
# 一般就是 https://${WULING_DOMAIN}
WULING_OAUTH_PUBLIC_BASE_URL=https://devops.example.com

# Secrets / 云凭证主密钥 — AES-256-GCM，32 字节（base64 或 hex）
# 生成: openssl rand -base64 32
# 不设置则每次重启随机生成临时密钥，已存机密（含云 AK/SK）将全部解不开 —— 生产必填！
WULING_SECRETS_KEY=__REPLACE_ME_OR_DIE__

# ---------------------------------------------------------------------------
# 服务运行参数 — 默认通常够用，看注释决定要不要改
# ---------------------------------------------------------------------------

WULING_ENV=prod
WULING_HTTP_ADDR=:8080
WULING_LOG_FORMAT=json
WULING_LOG_LEVEL=info

# JWT TTL — 过期后客户端会被强制重登
WULING_JWT_TTL=24h
WULING_JWT_ISSUER=wuling-devops
WULING_JWT_AUDIENCE=wuling-devops

# HTTP 超时
WULING_HTTP_READ_TIMEOUT=30s
WULING_HTTP_WRITE_TIMEOUT=30s
WULING_HTTP_IDLE_TIMEOUT=60s
WULING_HTTP_SHUTDOWN_TIMEOUT=15s

# 反代下如果有路径前缀，填这里（例如 https://example.com/wuling/）
WULING_HTTP_BASE_PATH=

# DB 连接池
WULING_DB_MAX_CONNS=20
WULING_DB_MIN_CONNS=2
WULING_DB_MAX_CONN_IDLE=15m
WULING_DB_MAX_CONN_LIFETIME=1h

# 仓库根 — 必须是持久卷
WULING_REPO_ROOT=/var/lib/wuling/repos

# ---------------------------------------------------------------------------
# Git SSH 子系统
# ---------------------------------------------------------------------------

WULING_SSH_ENABLED=true
WULING_SSH_ADDR=:2222
# 持久化，否则用户每次启动都要确认 host key 变更
WULING_SSH_HOST_KEY=/var/lib/wuling/ssh/host_ed25519

# ---------------------------------------------------------------------------
# Pipelines / Runner / Autoscaler (CI 子系统)
# ---------------------------------------------------------------------------

# job 日志落盘目录 — 必须是持久卷（artifact 存在其同级的 pipeline-artifacts/ 下）。
# 对应 compose 里挂到 /var/lib/wuling/pipelines 的 wuling-pipelines 卷。
WULING_PIPELINE_LOG_DIR=/var/lib/wuling/pipelines/logs

# 每个 org 的 Runner/Autoscaler 配置仓库定位（默认 {org}/config/config）：仓库默认分支
# 根目录的 runner-config.yaml 即该 org 的配置，走 GitOps + MR 评审。
WULING_RUNNER_CONFIG_PROJECT=config
WULING_RUNNER_CONFIG_REPO=config

# 注册令牌有效期（maintainer 在 UI 生成，用于手动注册 static runner）
WULING_RUNNER_REGISTRATION_TTL=1h
# runner 失联多久后回收其 running job 重新入队（达重试上限判失败）
WULING_RUNNER_REAP_AFTER=90s

# Autoscaler 协调循环：按各 org 的 runner-config.yaml 在云上拉起/释放临时 runner。
# 关掉则只保留 static runner + reaper（孤儿 job 仍会被回收）。云 AK/SK 以 org Secret
# 形式按池里的 credentials_secret 名称配置（见 docs/pipelines.md §4）；预装 runner 的
# 自定义镜像构建见 §7.1。
WULING_AUTOSCALER_ENABLED=true
WULING_AUTOSCALER_INTERVAL=20s
# runner-config.yaml 未声明 idle_timeout 时的回退空闲超时
WULING_AUTOSCALER_DEFAULT_IDLE_TIMEOUT=5m

# ---------------------------------------------------------------------------
# 注册审批 (默认开启 — 自托管实例的安全默认值)
# ---------------------------------------------------------------------------

# true = 新账号默认进入 pending 状态，必须由管理员在 /admin/users 批准之后才能登录
# false = 注册即登录（适合内部测试 / 完全开放的实例）
WULING_AUTH_REQUIRE_APPROVAL=true

# GitHub OAuth 注册的账号是否自动批准（前提是上面的 RequireApproval 已开启）
# true = 信任 GitHub 身份，跳过审批队列
# false = OAuth 注册和密码注册一样要审批（默认，最严格）
WULING_AUTH_OAUTH_AUTO_APPROVE=false

# ---------------------------------------------------------------------------
# GitHub OAuth 登录 (可选 — 不填则 /login 页面不会出现 "使用 GitHub 登录" 按钮)
# ---------------------------------------------------------------------------

# 在 https://github.com/settings/developers 创建 OAuth App，Callback URL
# 必须和下面的 REDIRECT_URL 完全一致（含协议和路径）。
# WULING_OAUTH_GITHUB_CLIENT_ID=
# WULING_OAUTH_GITHUB_CLIENT_SECRET=
# WULING_OAUTH_GITHUB_REDIRECT_URL=https://devops.example.com/api/v1/auth/oauth/github/callback

# 申请的 scope（逗号分隔）。默认覆盖读取基本资料和邮箱。如果你不想拿邮箱，删掉 user:email。
# WULING_OAUTH_GITHUB_SCOPES=read:user,user:email

# OAuth 回调完成后浏览器要跳回的前端基准 URL。空字符串或 "/" 表示当前域。
# 部署在子路径下（例如 https://example.com/wuling/）时填完整 URL 否则 fragment 会丢。
# WULING_OAUTH_FRONTEND_BASE_URL=https://devops.example.com

# 第一方桌面端 (Esperanta) 在 /.well-known/wuling-clients 里宣告的 client_id。
# 改这个值意味着已经发行的桌面端登录态全部作废 — 一般保持默认。
# WULING_OAUTH_DESKTOP_CLIENT_ID=wuling-desktop

# ---------------------------------------------------------------------------
# 仅 docker-compose.prod.yml 用到 — 用于 Caddy ACME
# ---------------------------------------------------------------------------

# 用于 Let's Encrypt 联系邮箱 (强烈推荐 — 证书过期会发邮件提醒)
ACME_EMAIL=you@example.com
